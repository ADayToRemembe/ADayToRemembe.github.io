---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  image?: string;
  math?: boolean;
  heroLayout?: boolean;
}

const {
  title,
  description = 'Academic portfolio and technical blog on Heat & Flow Engineering, CFD, and HVAC research.',
  image,
  math = false,
  heroLayout = false,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    {image && <meta property="og:image" content={new URL(image, Astro.site)} />}
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
  </head>
  <body class="min-h-screen flex flex-col bg-[#0a0a0f] text-slate-200">

    <!-- Nav: transparent on hero pages, solid otherwise -->
    <header class:list={[
      'fixed top-0 left-0 right-0 z-50 transition-all duration-300',
      heroLayout ? 'bg-transparent' : 'bg-[#0a0a0f]/90 backdrop-blur-md border-b border-white/5'
    ]} id="site-header">
      <nav class="max-w-6xl mx-auto px-6 py-5 flex items-center justify-between">
        <a href="/" class="font-bold text-xl text-white tracking-tight hover:opacity-80 transition-opacity">
          MBatu<span class="text-indigo-400">.</span>
        </a>
        <!-- Desktop nav -->
        <ul class="hidden md:flex items-center gap-8 text-sm font-medium text-slate-300">
          <li><a href="/" class="hover:text-white transition-colors">Home</a></li>
          <li><a href="/blog" class="hover:text-white transition-colors">Blog</a></li>
          <li><a href="/projects" class="hover:text-white transition-colors">Projects</a></li>
          <li><a href="/about" class="gradient-button !min-w-0 !px-5 !py-2 !text-sm !rounded-full">About</a></li>
        </ul>
        <!-- Hamburger button (mobile) -->
        <button id="menu-toggle" class="md:hidden flex flex-col gap-1.5 p-2 text-slate-300 hover:text-white" aria-label="Toggle menu" aria-expanded="false">
          <span class="block w-6 h-0.5 bg-current transition-all duration-300" id="bar1"></span>
          <span class="block w-6 h-0.5 bg-current transition-all duration-300" id="bar2"></span>
          <span class="block w-6 h-0.5 bg-current transition-all duration-300" id="bar3"></span>
        </button>
      </nav>
      <!-- Mobile dropdown menu -->
      <div id="mobile-menu" class="md:hidden hidden bg-[#0a0a0f]/95 backdrop-blur-md border-b border-white/5">
        <ul class="flex flex-col px-6 py-4 gap-4 text-sm font-medium text-slate-300">
          <li><a href="/" class="block py-2 hover:text-white transition-colors">Home</a></li>
          <li><a href="/blog" class="block py-2 hover:text-white transition-colors">Blog</a></li>
          <li><a href="/projects" class="block py-2 hover:text-white transition-colors">Projects</a></li>
          <li><a href="/about" class="gradient-button inline-block !min-w-0 !px-5 !py-2 !text-sm !rounded-full mt-1">About</a></li>
        </ul>
      </div>
    </header>

    <main class:list={['flex-1', heroLayout ? '' : 'pt-20']}>
      {heroLayout ? (
        <slot />
      ) : (
        <div class="max-w-5xl mx-auto w-full px-6 py-12">
          <slot />
        </div>
      )}
    </main>

    <footer class="border-t border-white/5 mt-20">
      <div class="max-w-6xl mx-auto px-6 py-10 flex flex-col sm:flex-row items-center justify-between gap-4 text-sm text-slate-500">
        <span>© {new Date().getFullYear()} MBatu — Aerospace & CFD Research</span>
        <div class="flex gap-6">
          <a href="https://github.com" class="hover:text-slate-300 transition-colors" target="_blank" rel="noopener">GitHub</a>
          <a href="https://linkedin.com" class="hover:text-slate-300 transition-colors" target="_blank" rel="noopener">LinkedIn</a>
          <a href="https://twitter.com" class="hover:text-slate-300 transition-colors" target="_blank" rel="noopener">Twitter</a>
        </div>
      </div>
    </footer>

    <!-- Hamburger menu toggle -->
    <script>
      const toggle = document.getElementById('menu-toggle');
      const menu = document.getElementById('mobile-menu');
      const bar1 = document.getElementById('bar1');
      const bar2 = document.getElementById('bar2');
      const bar3 = document.getElementById('bar3');
      toggle?.addEventListener('click', () => {
        const open = menu?.classList.toggle('hidden') === false;
        toggle.setAttribute('aria-expanded', String(open));
        if (open) {
          bar1?.classList.add('translate-y-2', 'rotate-45');
          bar2?.classList.add('opacity-0');
          bar3?.classList.add('-translate-y-2', '-rotate-45');
        } else {
          bar1?.classList.remove('translate-y-2', 'rotate-45');
          bar2?.classList.remove('opacity-0');
          bar3?.classList.remove('-translate-y-2', '-rotate-45');
        }
      });
    </script>

    <!-- Scroll handler: darken transparent header on scroll -->
    {heroLayout && (
      <script>
        const header = document.getElementById('site-header');
        window.addEventListener('scroll', () => {
          if (window.scrollY > 50) {
            header?.classList.add('bg-[#0a0a0f]/90', 'backdrop-blur-md', 'border-b', 'border-white/5');
            header?.classList.remove('bg-transparent');
          } else {
            header?.classList.remove('bg-[#0a0a0f]/90', 'backdrop-blur-md', 'border-b', 'border-white/5');
            header?.classList.add('bg-transparent');
          }
        }, { passive: true });
      </script>
    )}
  </body>
</html>
