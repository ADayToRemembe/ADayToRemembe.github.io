---
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import AnimatedShaderHero from '../components/ui/animated-shader-hero';
import RocketLaunch from '../components/ui/rocket-launch';
import DemoGames from '../components/ui/demo-games';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const allProjects = await getCollection('projects');

const recentPosts = allPosts
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

const recentProjects = allProjects
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);
---

<BaseLayout title="B_AYAN — Heat & Flow Engineering & CFD Research" heroLayout={true}>

  <!-- ─── HERO: WebGL Shader Background ─── -->
  <AnimatedShaderHero
    client:load
    trustBadge={{ text: "Mechanical Engineer & CFD Researcher", icons: ["🌀"] }}
    headline={{ line1: "Pushing the Boundaries", line2: "of Engineering." }}
    subtitle="Research in rocket propulsion, eco-friendly HVAC systems, and computational fluid dynamics. Sharing the math, methods, and simulations behind Heat & Flow Engineering."
    buttons={{
      primary:   { text: "Read the Blog",   href: "/blog" },
      secondary: { text: "View Projects",   href: "/projects" },
    }}
  />

  <!-- ─── ROCKET LAUNCH SECTION ─── -->
  <RocketLaunch client:visible />


<!-- ─── RECENT POSTS ─── -->
  {recentPosts.length > 0 && (
    <section class="py-24 px-6 border-b border-white/5">
      <div class="max-w-6xl mx-auto">
        <div class="flex items-end justify-between mb-12">
          <div>
            <p class="text-xs font-semibold text-indigo-400 tracking-widest uppercase mb-2">Technical Writing</p>
            <h2 class="text-3xl font-bold text-white">Recent Posts</h2>
          </div>
          <a href="/blog" class="text-sm text-slate-400 hover:text-white transition-colors hidden sm:block">All posts →</a>
        </div>
        <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
          {recentPosts.map((post) => (
            <PostCard
              title={post.data.title}
              description={post.data.description}
              slug={post.id}
              pubDate={post.data.pubDate}
              tags={post.data.tags}
              collection="blog"
            />
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- ─── RECENT PROJECTS ─── -->
  {recentProjects.length > 0 && (
    <section class="py-24 px-6">
      <div class="max-w-6xl mx-auto">
        <div class="flex items-end justify-between mb-12">
          <div>
            <p class="text-xs font-semibold text-indigo-400 tracking-widest uppercase mb-2">Research Work</p>
            <h2 class="text-3xl font-bold text-white">Projects</h2>
          </div>
          <a href="/projects" class="text-sm text-slate-400 hover:text-white transition-colors hidden sm:block">All projects →</a>
        </div>
        <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
          {recentProjects.map((project) => (
            <PostCard
              title={project.data.title}
              description={project.data.description}
              slug={project.id}
              pubDate={project.data.pubDate}
              tags={project.data.tags}
              collection="projects"
            />
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- ─── DEMO GAMES ─── -->
  <DemoGames client:visible />

</BaseLayout>
