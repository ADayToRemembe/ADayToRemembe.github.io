---
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import AnimatedShaderHero from '../components/ui/animated-shader-hero';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const allProjects = await getCollection('projects');

const recentPosts = allPosts
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

const recentProjects = allProjects
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);
---

<BaseLayout title="MBatu — Heat & Flow Engineering & CFD Research" heroLayout={true}>

  <!-- ─── HERO: WebGL Shader Background ─── -->
  <AnimatedShaderHero
    client:load
    trustBadge={{ text: "Heat & Flow Engineer & CFD Researcher", icons: ["🚀"] }}
    headline={{ line1: "Pushing the Boundaries", line2: "of Engineering." }}
    subtitle="Research in rocket propulsion, eco-friendly HVAC systems, and computational fluid dynamics. Sharing the math, methods, and simulations behind Heat & Flow Engineering."
    buttons={{
      primary:   { text: "Read the Blog",   href: "/blog" },
      secondary: { text: "View Projects",   href: "/projects" },
    }}
  />

  <!-- ─── ABOUT / INTRO SECTION ─── -->
  <section class="py-24 px-6 border-b border-white/5">
    <div class="max-w-6xl mx-auto grid md:grid-cols-2 gap-16 items-center">
      <div>
        <h2 class="text-3xl font-bold text-white mb-4">Pushing the boundaries of space.</h2>
        <p class="text-slate-400 leading-relaxed mb-6">
          I research advanced propulsion systems, RANS turbulence modeling, and CFD simulation
          techniques. My work spans from supersonic nozzle analysis to eco-friendly HVAC design —
          always grounded in the governing equations of fluid mechanics.
        </p>
        <div class="flex flex-wrap gap-3">
          {['Rocket Design', 'CFD / OpenFOAM', 'RANS Modeling', 'Eco HVAC', 'Python / MATLAB'].map(tag => (
            <span class="text-xs px-3 py-1 bg-slate-800 text-slate-300 rounded-full border border-slate-700">
              {tag}
            </span>
          ))}
        </div>
      </div>

      <div class="grid grid-cols-2 gap-4">
        {[
          { label: 'Research Areas', value: '4+',          sub: 'Active topics' },
          { label: 'CFD Simulations', value: '20+',        sub: 'Completed cases' },
          { label: 'Publications',   value: 'In progress', sub: 'Academic papers' },
          { label: 'Open Source',    value: 'GitHub',      sub: 'All code public' },
        ].map(item => (
          <div class="bg-slate-900/60 border border-white/5 rounded-xl p-5">
            <div class="text-2xl font-bold text-white mb-1">{item.value}</div>
            <div class="text-sm font-medium text-slate-300">{item.label}</div>
            <div class="text-xs text-slate-500 mt-0.5">{item.sub}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ─── RECENT POSTS ─── -->
  {recentPosts.length > 0 && (
    <section class="py-24 px-6 border-b border-white/5">
      <div class="max-w-6xl mx-auto">
        <div class="flex items-end justify-between mb-12">
          <div>
            <p class="text-xs font-semibold text-indigo-400 tracking-widest uppercase mb-2">Technical Writing</p>
            <h2 class="text-3xl font-bold text-white">Recent Posts</h2>
          </div>
          <a href="/blog" class="text-sm text-slate-400 hover:text-white transition-colors hidden sm:block">All posts →</a>
        </div>
        <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
          {recentPosts.map((post) => (
            <PostCard
              title={post.data.title}
              description={post.data.description}
              slug={post.id}
              pubDate={post.data.pubDate}
              tags={post.data.tags}
              collection="blog"
            />
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- ─── RECENT PROJECTS ─── -->
  {recentProjects.length > 0 && (
    <section class="py-24 px-6">
      <div class="max-w-6xl mx-auto">
        <div class="flex items-end justify-between mb-12">
          <div>
            <p class="text-xs font-semibold text-indigo-400 tracking-widest uppercase mb-2">Research Work</p>
            <h2 class="text-3xl font-bold text-white">Projects</h2>
          </div>
          <a href="/projects" class="text-sm text-slate-400 hover:text-white transition-colors hidden sm:block">All projects →</a>
        </div>
        <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
          {recentProjects.map((project) => (
            <PostCard
              title={project.data.title}
              description={project.data.description}
              slug={project.id}
              pubDate={project.data.pubDate}
              tags={project.data.tags}
              collection="projects"
            />
          ))}
        </div>
      </div>
    </section>
  )}

</BaseLayout>
