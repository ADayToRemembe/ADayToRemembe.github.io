---
import BaseLayout from '../layouts/BaseLayout.astro';
import AnimatedShaderHero from '../components/ui/animated-shader-hero';
import RocketLaunch from '../components/ui/rocket-launch';
import { getCollection } from 'astro:content';

const allPosts    = await getCollection('blog', ({ data }) => !data.draft);
const allProjects = await getCollection('projects');

const recentPosts = allPosts
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3)
  .map(p => ({ title: p.data.title, slug: p.id, tags: (p.data.tags ?? []).slice(0, 2) }));

const recentProjects = allProjects
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3)
  .map(p => ({ title: p.data.title, slug: p.id, tags: (p.data.tags ?? []).slice(0, 2) }));
---

<BaseLayout title="B_AYAN — Heat & Flow Engineering & CFD Research" heroLayout={true}>

  <!-- ─── HERO ─── -->
  <AnimatedShaderHero
    client:load
    trustBadge={{ text: "Mechanical Engineer & CFD Researcher", icons: ["🌀"] }}
    headline={{ line1: "Pushing the Boundaries", line2: "of Engineering." }}
    subtitle="Research in rocket propulsion, eco-friendly HVAC systems, and computational fluid dynamics. Sharing the math, methods, and simulations behind Heat & Flow Engineering."
    buttons={{
      primary:   { text: "Read the Blog",  href: "/blog" },
      secondary: { text: "View Projects",  href: "/projects" },
    }}
  />

  <!-- ─── ROCKET LAUNCH (covers posts + projects in cruise phase) ─── -->
  <RocketLaunch client:visible posts={recentPosts} projects={recentProjects} />

</BaseLayout>
