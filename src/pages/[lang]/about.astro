---
import BaseLayout from '../../layouts/BaseLayout.astro';
import LiquidHero from '../../components/ui/LiquidHero.astro';
import { type Lang, ui } from '../../i18n/translations';

export function getStaticPaths() {
  return [
    { params: { lang: 'tr' } },
    { params: { lang: 'de' } },
    { params: { lang: 'ru' } },
  ];
}

const { lang } = Astro.params as { lang: Lang };
const T = ui[lang];
---

<BaseLayout
  title={`${T['about.heading']} — B_AYAN`}
  description={T['about.bio']}
  lang={lang}
>
  <!-- Full-page liquid background -->
  <LiquidHero />

  <style is:global>
    body { background-color: transparent !important; }
    html { background-color: #0a0a0f; }

    #liquid-canvas {
      position: fixed;
      inset: 0;
      width: 100%;
      height: 100%;
      z-index: -1;
      pointer-events: none;
      filter: hue-rotate(215deg) saturate(1.2) brightness(0.55);
    }
    #liquid-overlay {
      position: fixed;
      inset: 0;
      background: linear-gradient(
        160deg,
        rgba(5, 5, 20, 0.60) 0%,
        rgba(15, 10, 60, 0.30) 45%,
        rgba(5, 5, 20, 0.75) 100%
      );
      z-index: -1;
      pointer-events: none;
    }
  </style>

  <div class="max-w-2xl">
    <div class="prose">
      <p>{T['about.bio']}</p>

      <h2>{T['about.interests.heading']}</h2>
      <ul>
        <li>{T['about.interests.1']}</li>
        <li>{T['about.interests.2']}</li>
        <li>{T['about.interests.3']}</li>
        <li>{T['about.interests.4']}</li>
      </ul>

      <h2>{T['about.tools.heading']}</h2>
      <ul>
        <li>{T['about.tools.1']}</li>
        <li>{T['about.tools.2']}</li>
        <li>{T['about.tools.3']}</li>
        <li>{T['about.tools.4']}</li>
      </ul>

      <h2>{T['about.contact.heading']}</h2>
      <p>
        {T['about.contact.text']}{' '}
        <a href="https://www.linkedin.com/in/batu-ayan-b63673151" target="_blank" rel="noopener">LinkedIn</a>{' '}
        {T['about.contact.or']}{' '}
        <a href="https://github.com/adaytoremembe" target="_blank" rel="noopener">GitHub</a>.
      </p>
    </div>
  </div>
</BaseLayout>
