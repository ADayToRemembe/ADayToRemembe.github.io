---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import AnimatedShaderHero from '../../components/ui/animated-shader-hero';
import RocketLaunch from '../../components/ui/rocket-launch';
import { getCollection } from 'astro:content';
import { type Lang, ui } from '../../i18n/translations';

export function getStaticPaths() {
  return [
    { params: { lang: 'tr' } },
    { params: { lang: 'de' } },
    { params: { lang: 'ru' } },
  ];
}

const { lang } = Astro.params as { lang: Lang };
const T = ui[lang];
const prefix = `/${lang}`;

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const allProjects = await getCollection('projects');

const recentPosts = allPosts
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

const recentProjects = allProjects
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);
---

<BaseLayout title={`B_AYAN — ${T['hero.badge']}`} heroLayout={true} lang={lang}>

  <AnimatedShaderHero
    client:load
    trustBadge={{ text: T['hero.badge'], icons: ['🌀'] }}
    headline={{ line1: T['hero.line1'], line2: T['hero.line2'] }}
    subtitle={T['hero.subtitle']}
    buttons={{
      primary:   { text: T['hero.primary'],   href: `${prefix}/blog` },
      secondary: { text: T['hero.secondary'], href: `${prefix}/projects` },
    }}
  />

  <!-- ROCKET LAUNCH SECTION -->
  <RocketLaunch client:visible />

  <!-- ABOUT / INTRO SECTION -->
  <section class="py-24 px-6 border-b border-white/5">
    <div class="max-w-6xl mx-auto grid md:grid-cols-2 gap-16 items-center">
      <div>
        <h2 class="text-3xl font-bold text-white mb-4">{T['home.intro.heading']}</h2>
        <p class="text-slate-400 leading-relaxed mb-6">{T['home.intro.text']}</p>
        <div class="flex flex-wrap gap-3">
          {['Rocket Design', 'CFD / OpenFOAM', 'RANS Modeling', 'Eco HVAC', 'Python / MATLAB'].map(tag => (
            <span class="text-xs px-3 py-1 bg-slate-800 text-slate-300 rounded-full border border-slate-700">
              {tag}
            </span>
          ))}
        </div>
      </div>

      <div class="grid grid-cols-2 gap-4">
        {[
          { label: T['home.stat.research.label'], value: '4+',          sub: T['home.stat.research.sub'] },
          { label: T['home.stat.cfd.label'],      value: '20+',         sub: T['home.stat.cfd.sub'] },
          { label: T['home.stat.pub.label'],      value: 'In progress', sub: T['home.stat.pub.sub'] },
          { label: T['home.stat.oss.label'],      value: 'GitHub',      sub: T['home.stat.oss.sub'] },
        ].map(item => (
          <div class="bg-slate-900/60 border border-white/5 rounded-xl p-5">
            <div class="text-2xl font-bold text-white mb-1">{item.value}</div>
            <div class="text-sm font-medium text-slate-300">{item.label}</div>
            <div class="text-xs text-slate-500 mt-0.5">{item.sub}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- RECENT POSTS -->
  {recentPosts.length > 0 && (
    <section class="py-24 px-6 border-b border-white/5">
      <div class="max-w-6xl mx-auto">
        <div class="flex items-end justify-between mb-12">
          <div>
            <p class="text-xs font-semibold text-indigo-400 tracking-widest uppercase mb-2">{T['home.posts.eyebrow']}</p>
            <h2 class="text-3xl font-bold text-white">{T['home.posts.heading']}</h2>
          </div>
          <a href={`${prefix}/blog`} class="text-sm text-slate-400 hover:text-white transition-colors hidden sm:block">{T['home.posts.all']}</a>
        </div>
        <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
          {recentPosts.map((post) => (
            <PostCard
              title={post.data.title}
              description={post.data.description}
              slug={post.id}
              pubDate={post.data.pubDate}
              tags={post.data.tags}
              collection="blog"
            />
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- RECENT PROJECTS -->
  {recentProjects.length > 0 && (
    <section class="py-24 px-6">
      <div class="max-w-6xl mx-auto">
        <div class="flex items-end justify-between mb-12">
          <div>
            <p class="text-xs font-semibold text-indigo-400 tracking-widest uppercase mb-2">{T['home.projects.eyebrow']}</p>
            <h2 class="text-3xl font-bold text-white">{T['home.projects.heading']}</h2>
          </div>
          <a href={`${prefix}/projects`} class="text-sm text-slate-400 hover:text-white transition-colors hidden sm:block">{T['home.projects.all']}</a>
        </div>
        <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
          {recentProjects.map((project) => (
            <PostCard
              title={project.data.title}
              description={project.data.description}
              slug={project.id}
              pubDate={project.data.pubDate}
              tags={project.data.tags}
              collection="projects"
            />
          ))}
        </div>
      </div>
    </section>
  )}

</BaseLayout>
