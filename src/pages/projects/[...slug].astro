---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((project) => ({
    params: { slug: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);
const { title, description, pubDate, tags, status, github, paper } = project.data;

const statusColors = {
  active: 'text-green-400 bg-green-950 border-green-900',
  completed: 'text-blue-400 bg-blue-950 border-blue-900',
  archived: 'text-slate-400 bg-slate-900 border-slate-700',
};
---

<BaseLayout title={`${title} — MBatu`} description={description} math={true}>
  <article>
    <header class="mb-10 pb-8 border-b border-slate-800">
      <div class="flex flex-wrap gap-2 mb-4">
        <span class={`text-xs px-2.5 py-1 rounded-full border ${statusColors[status]}`}>
          {status}
        </span>
        {tags.map((tag) => (
          <span class="text-xs px-2.5 py-1 rounded-full bg-indigo-950 text-indigo-400 border border-indigo-800">
            {tag}
          </span>
        ))}
      </div>
      <h1 class="text-3xl sm:text-4xl font-bold text-white mb-4 leading-tight">{title}</h1>
      <p class="text-slate-400 text-lg mb-4">{description}</p>
      <div class="flex items-center gap-4 text-sm">
        <time class="text-slate-500" datetime={pubDate.toISOString()}>
          {pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long' })}
        </time>
        {github && (
          <a href={github} class="text-indigo-400 hover:text-indigo-300 transition-colors" target="_blank" rel="noopener">
            GitHub →
          </a>
        )}
        {paper && (
          <a href={paper} class="text-indigo-400 hover:text-indigo-300 transition-colors" target="_blank" rel="noopener">
            Paper →
          </a>
        )}
      </div>
    </header>

    <div class="prose">
      <Content />
    </div>
  </article>
</BaseLayout>
