---
import { type Lang, languages } from '../i18n/translations';

interface Props {
  currentLang: Lang;
}

const { currentLang } = Astro.props;
const currentPath = Astro.url.pathname;

function getTargetUrl(targetLang: Lang): string {
  const cleanPath = currentPath.replace(/^\/(tr|de|ru)(?=\/|$)/, '') || '/';
  if (targetLang === 'en') return cleanPath || '/';
  return `/${targetLang}${cleanPath === '/' ? '' : cleanPath}` || `/${targetLang}`;
}

const current = languages[currentLang];
---

<div class="relative z-[60]" data-lang-switcher>
  <!-- Trigger button -->
  <button
    data-lang-button
    class="flex items-center gap-1.5 rounded-xl border border-amber-600/50 bg-slate-800/40 px-2.5 py-1.5 hover:border-amber-500/80 hover:bg-slate-700/50 transition-all duration-200 cursor-pointer"
    aria-haspopup="listbox"
    aria-expanded="false"
    aria-label="Select language"
    type="button"
    style="touch-action: manipulation; -webkit-tap-highlight-color: transparent;"
  >
    <img
      src={`https://flagcdn.com/w20/${current.flagCode}.png`}
      srcset={`https://flagcdn.com/w40/${current.flagCode}.png 2x`}
      width="20"
      height="15"
      alt={current.nativeName}
      class="rounded-sm object-cover flex-shrink-0"
    />
    <!-- Show language code + chevron on both mobile and desktop -->
    <span class="text-xs font-semibold text-slate-300 tracking-wide">{currentLang.toUpperCase()}</span>
    <svg class="w-3 h-3 text-slate-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
    </svg>
  </button>

  <!-- Dropdown -->
  <ul
    data-lang-dropdown
    role="listbox"
    aria-label="Language selection"
    class="absolute right-0 top-full mt-2 min-w-[9rem] rounded-xl bg-[#0f0f18] border border-white/10 shadow-2xl hidden z-[999] py-1 overflow-hidden"
  >
    {(Object.keys(languages) as Lang[]).map((lang) => (
      <li role="option" aria-selected={lang === currentLang}>
        <a
          href={getTargetUrl(lang)}
          class:list={[
            'flex items-center gap-2.5 px-3 py-2.5 text-sm transition-colors',
            lang === currentLang
              ? 'bg-indigo-600/20 text-indigo-300 font-medium'
              : 'text-slate-300 hover:bg-slate-800/80 hover:text-white',
          ]}
        >
          <img
            src={`https://flagcdn.com/w20/${languages[lang].flagCode}.png`}
            srcset={`https://flagcdn.com/w40/${languages[lang].flagCode}.png 2x`}
            width="20"
            height="15"
            alt={languages[lang].nativeName}
            class="rounded-sm object-cover flex-shrink-0"
          />
          <span class="font-semibold tracking-wide text-xs">{lang.toUpperCase()}</span>
          <span class="text-slate-500 text-xs">{languages[lang].nativeName}</span>
          {lang === currentLang && (
            <svg class="ml-auto w-3.5 h-3.5 text-indigo-400 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
              <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
            </svg>
          )}
        </a>
      </li>
    ))}
  </ul>
</div>

<script>
  function initLangSwitchers() {
    const switchers = document.querySelectorAll<HTMLElement>('[data-lang-switcher]');

    switchers.forEach((switcher) => {
      const button   = switcher.querySelector<HTMLElement>('[data-lang-button]');
      const dropdown = switcher.querySelector<HTMLElement>('[data-lang-dropdown]');
      if (!button || !dropdown) return;

      button.addEventListener('click', (e) => {
        e.preventDefault();
        const isOpen = !dropdown.classList.contains('hidden');
        // Close all other dropdowns first
        document.querySelectorAll<HTMLElement>('[data-lang-dropdown]').forEach(d => {
          if (d !== dropdown) d.classList.add('hidden');
        });
        document.querySelectorAll<HTMLElement>('[data-lang-button]').forEach(b => {
          if (b !== button) b.setAttribute('aria-expanded', 'false');
        });
        dropdown.classList.toggle('hidden', isOpen);
        button.setAttribute('aria-expanded', String(!isOpen));
      });
    });

    // Close on outside click or touch
    function closeOnOutside(e: Event) {
      document.querySelectorAll<HTMLElement>('[data-lang-switcher]').forEach((switcher) => {
        if (!switcher.contains(e.target as Node)) {
          const dropdown = switcher.querySelector<HTMLElement>('[data-lang-dropdown]');
          const button   = switcher.querySelector<HTMLElement>('[data-lang-button]');
          dropdown?.classList.add('hidden');
          button?.setAttribute('aria-expanded', 'false');
        }
      });
    }

    document.addEventListener('click', closeOnOutside);
    document.addEventListener('touchstart', closeOnOutside, { passive: true });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') {
        document.querySelectorAll<HTMLElement>('[data-lang-dropdown]').forEach(d => d.classList.add('hidden'));
        document.querySelectorAll<HTMLElement>('[data-lang-button]').forEach(b => b.setAttribute('aria-expanded', 'false'));
      }
    });
  }

  initLangSwitchers();
</script>
