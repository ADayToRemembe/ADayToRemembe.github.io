---
interface Props {
  title: string;
  description: string;
  slug: string;
  pubDate: Date;
  tags: string[];
  collection: 'blog' | 'projects';
}

const { title, description, slug, pubDate, tags, collection } = Astro.props;

const formattedDate = pubDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});

const href = `/${collection}/${slug}`;
---

<article class="group border border-slate-800 rounded-xl p-6 hover:border-slate-600 transition-all duration-200 bg-slate-900/30 hover:bg-slate-900/60">
  <div class="flex flex-wrap gap-2 mb-3">
    {tags.map((tag) => (
      <span class="text-xs px-2 py-0.5 rounded-full bg-indigo-950 text-indigo-400 border border-indigo-900">
        {tag}
      </span>
    ))}
  </div>
  <h2 class="text-xl font-semibold text-white mb-2 group-hover:text-indigo-300 transition-colors">
    <a href={href}>{title}</a>
  </h2>
  <p class="text-slate-400 text-sm leading-relaxed mb-4">{description}</p>
  <div class="flex items-center justify-between">
    <time class="text-xs text-slate-500">{formattedDate}</time>
    <a href={href} class="gradient-button !min-w-0 !px-4 !py-1.5 !text-xs !rounded-lg">
      Read more →
    </a>
  </div>
</article>
