---
// Full-page liquid background.
// Requires the consuming page to set body { background: transparent }
// so the z:-1 fixed canvas is visible. See about.astro for the page-level style.
---

<canvas id="liquid-canvas"></canvas>
<div id="liquid-overlay"></div>

<script type="module">
  import LiquidBackground from
    'https://cdn.jsdelivr.net/npm/threejs-components@0.0.27/build/backgrounds/liquid1.min.js';

  const canvas = document.getElementById('liquid-canvas');
  if (!canvas) return;

  // Set explicit pixel dimensions before Three.js initialises
  canvas.width  = window.innerWidth;
  canvas.height = window.innerHeight;

  const app = LiquidBackground(canvas);
  app.loadImage('/reflection-pond.jpg');
  app.liquidPlane.material.metalness = 0.88;
  app.liquidPlane.material.roughness = 0.14;
  app.liquidPlane.uniforms.displacementScale.value = 3.5;
  app.setRain(false);

  // Keep the renderer filling the full viewport on resize
  window.addEventListener('resize', () => {
    const w = window.innerWidth;
    const h = window.innerHeight;
    canvas.width  = w;
    canvas.height = h;
    if (app.renderer) {
      app.renderer.setSize(w, h, false);
    }
    if (app.camera) {
      app.camera.aspect = w / h;
      app.camera.updateProjectionMatrix();
    }
  }, { passive: true });
</script>
