---
// Full-page liquid background.
// Requires the consuming page to set body { background: transparent }
// so the z:-1 fixed canvas is visible. See about.astro for the page-level style.
---

<canvas id="liquid-canvas"></canvas>
<div id="liquid-overlay"></div>

<script type="module">
  import LiquidBackground from
    'https://cdn.jsdelivr.net/npm/threejs-components@0.0.27/build/backgrounds/liquid1.min.js';

  const canvas = document.getElementById('liquid-canvas');
  if (canvas) {
    const app = LiquidBackground(canvas);
    app.liquidPlane.material.metalness = 0.92;
    app.liquidPlane.material.roughness = 0.12;
    app.liquidPlane.uniforms.displacementScale.value = 3;
    app.setRain(false);
  }
</script>
