---
// No props — this component injects a fixed full-page liquid background
// and a colour-matching overlay. Include it once in a page to cover the
// entire viewport behind all other content.
---

<canvas id="liquid-canvas"></canvas>
<div class="liquid-overlay"></div>

<style is:global>
  #liquid-canvas {
    position: fixed;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
    display: block;
    pointer-events: none;
  }

  .liquid-overlay {
    position: fixed;
    inset: 0;
    background: linear-gradient(
      160deg,
      rgba(10, 10, 15, 0.55) 0%,
      rgba(30, 27, 75, 0.35) 50%,
      rgba(10, 10, 15, 0.70) 100%
    );
    z-index: 0;
    pointer-events: none;
  }

  /* Lift every direct child of <body> above the liquid background */
  body > * {
    position: relative;
    z-index: 1;
  }
</style>

<script type="module">
  import LiquidBackground from
    'https://cdn.jsdelivr.net/npm/threejs-components@0.0.27/build/backgrounds/liquid1.min.js';

  const canvas = document.getElementById('liquid-canvas');
  if (canvas) {
    const app = LiquidBackground(canvas);
    app.loadImage('https://assets.codepen.io/33787/liquid.webp');
    app.liquidPlane.material.metalness = 0.85;
    app.liquidPlane.material.roughness = 0.18;
    app.liquidPlane.uniforms.displacementScale.value = 4;
    app.setRain(false);
  }
</script>
